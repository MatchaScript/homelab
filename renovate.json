{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests"
  ],
  "baseBranches": ["main"],
  "dockerfile": {
    "fileMatch": [
      "(^|/|\\.)Containerfile$",
      "(^|/)Containerfile[^/]*$"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)Chart\\.yaml$"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s*depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s+appVersion:\\s*[\"']?(?<currentValue>.+?)[\"']?\\s"
      ]
    },
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)kustomize/[^/]+/kustomization\\.yaml$"
      ],
      "matchStrings": [
        "raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/(?<currentValue>[^/]+)/"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/[^/]+\\.ya?ml$"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s+\\S+:\\s*[\"']?[^\"'\\s:]+:(?<currentValue>[^@\"'\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?[\"']?"
      ]
    },
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/|\\.)Containerfile$",
        "(^|/)Containerfile[^/]*$"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s+ARG\\s+\\w+=[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge fedora-bootc base image digest bumps (gated by the Verify Base Images check). Scoped to this dep only for now; other updates stay manual. NOTE: this trusts the official Fedora upstream (quay.io/fedora/fedora-bootc); the gate is a build+smoke check, not an upstream-provenance check (Fedora does not sigstore-sign these images), so this is an accepted-risk auto-merge.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "quay.io/fedora/fedora-bootc"
      ],
      "matchUpdateTypes": [
        "digest",
        "pin"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group all Helm chart updates together",
      "matchManagers": [
        "helmv3"
      ],
      "groupName": "helm charts"
    },
    {
      "description": "Group all GitHub Actions updates together",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions"
    },
    {
      "description": "Strip leading 'v' from actions/runner* GitHub release tags",
      "matchDatasources": ["github-releases"],
      "matchPackageNames": [
        "actions/runner",
        "actions/runner-container-hooks"
      ],
      "extractVersion": "^v(?<version>.+)$"
    }
  ]
}
